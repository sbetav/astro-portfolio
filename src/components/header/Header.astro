---
import MaxWidthWrapper from "../MaxWidthWrapper.astro";
import HeaderMenu from "./HeaderMenu";
---

<div class="sticky top-0 z-[1000] w-full">
  <div
    class="w-full border-b border-black bg-amber-100 px-4 py-2 text-center text-sm font-medium text-black"
  >
    Site under renovation. New version coming soon. 🚧
  </div>

  <header class="w-full border-b border-black bg-white/50 backdrop-blur-lg">
    <MaxWidthWrapper
      className="relative flex items-center justify-between py-6"
    >
      <a href="/" class="select-none font-serif text-4xl">S.</a>
      <HeaderMenu client:visible />
    </MaxWidthWrapper>
  </header>
</div>
